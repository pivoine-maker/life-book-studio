{
  "name": "life-book-studio",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.8.3"
  },
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm -r run --if-present build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "clean:material": "python3 tools/material_cleaner.py",
    "clean:material:dry-run": "python3 tools/material_cleaner.py --dry-run"
  }
}
